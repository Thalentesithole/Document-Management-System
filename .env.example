# ==========================================
# Frontend Variables (Vercel)
# ==========================================
VITE_API_URL=https://api.yourdomain.com/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ==========================================
# Backend Variables (Railway / Render)
# ==========================================

# Database & Storage
DATABASE_URL=postgresql+asyncpg://user:password@db.host:5432/dbname
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# API Keys
GEMINI_API_KEY=your-gemini-api-key
RESEND_API_KEY=re_your_resend_api_key

# Authentication & Security
JWT_SECRET_KEY=your-secure-random-jwt-secret-key-at-least-32-chars

# Redis (Celery & Rate Limiting)
REDIS_URL=redis://default:password@redis.host:6379/0

# Email Delivery
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Monitoring & Logging
SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0

# URLs
FRONTEND_URL=https://app.yourdomain.com
BACKEND_URL=https://api.yourdomain.com
